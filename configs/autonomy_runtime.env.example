# Runtime defaults for scripts/run_autonomy_sitl.sh.

MAVLINK_CONNECTION="udp:127.0.0.1:14550"

# Optional override if `drone-autonomy` is not installed in PATH and you want the
# launcher to use a specific Python environment.
# PYTHON_BIN="/media/gedxxe/DATA/venv-ardupilot/bin/python"

# Use "none" for telemetry/command dry-run only, "synthetic" to emulate gate
# detections, or "webots-yolo" to read iris_camera.wbt's TCP camera stream and
# run YOLO before producing GateDetection.
DETECTOR="synthetic"

# Required only for DETECTOR="webots-yolo". The repo profile uses the trained
# gate model under models/ and accepts its class id 0.
# YOLO_MODEL_PATH="${REPO_ROOT}/models/gate_yolov8n_best.pt"
YOLO_CONFIDENCE="0.35"
YOLO_IMGSZ="640"
YOLO_GATE_CLASS_NAMES=""
YOLO_GATE_CLASS_IDS="0"
YOLO_DEVICE="cpu"
YOLO_CONFIG_DIR="${REPO_ROOT}/.tmp_ultralytics"

# ArduPilot's vendored iris_camera.wbt streams grayscale camera frames on TCP
# port 5599. The autonomy adapter expands gray8 to three channels for YOLO.
WEBOTS_CAMERA_HOST="127.0.0.1"
WEBOTS_CAMERA_PORT="5599"
WEBOTS_CAMERA_ENCODING="gray8"

# Safety default: 0 means do not send MAVLink movement commands.
# Set to 1 only when connected to SITL and ready to let the vehicle move.
SEND_COMMANDS="0"

LOOP_HZ="20"
MAX_RUNTIME="180"

# Course-forward projection from LOCAL_POSITION_NED.
# Defaults to local x/North. Change this when the Webots course direction is known.
COURSE_FORWARD_X="1.0"
COURSE_FORWARD_Y="0.0"
