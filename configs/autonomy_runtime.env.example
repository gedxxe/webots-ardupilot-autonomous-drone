# Local runtime tuning template for scripts/run_autonomy_sitl.sh.
#
# Copy this file to configs/autonomy_runtime.env for persistent experiments.
# The launcher only forwards values that are present here or passed inline.
# Python runtime defaults remain the code-level fallback; this file is the
# operator-facing starting preset for iris_camera.wbt + YOLO diagnostics.

# Use a separate SITL MAVLink output from Mission Planner. Keep Mission Planner
# on 14550 and point this autonomy runtime at 14551 when MAVLINK_OUT_EXTRA is
# enabled in configs/sitl_webots.env.
MAVLINK_CONNECTION="udp:127.0.0.1:14551"
# Serial baud used when MAVLINK_CONNECTION is a device such as /dev/ttyACM0.
# UDP SITL endpoints ignore this pymavlink setting, so the simulation default
# remains unchanged.
MAVLINK_BAUD="115200"

# Optional override if `drone-autonomy` is not installed in PATH and you want the
# launcher to use a specific Python environment.
# PYTHON_BIN="/media/gedxxe/DATA/venv-ardupilot/bin/python"

# Current iris_camera.wbt simulation flow uses Webots camera frames plus YOLO.
# scripts/run_iris_camera_yolo.sh will enforce this detector unless DETECTOR is
# passed inline, so stale local config cannot accidentally run synthetic mode.
DETECTOR="webots-yolo"

# Required only for DETECTOR="webots-yolo". The bundled multi-class simulation
# model maps the gate to class id 3 with label Goals-Detection. Keep both the
# name and id filters active during motion tests so Dog/Forklift/Table boxes
# cannot become flight targets.
YOLO_MODEL_PATH="${REPO_ROOT}/models/gate_yolov8n_best.pt"
YOLO_CONFIDENCE="0.35"
# Ultralytics inference size, not camera resolution. The Webots frame remains
# 640x480; YOLO letterboxes/resizes it internally to this square imgsz.
YOLO_IMGSZ="640"
YOLO_GATE_CLASS_NAMES="Goals-Detection"
YOLO_GATE_CLASS_IDS="3"
YOLO_DEVICE="cpu"
YOLO_CONFIG_DIR="${REPO_ROOT}/.tmp_ultralytics"

# ---------------------------------------------------------------------------
# 1) Target selector: make the selected bbox stable before tuning movement.
# ---------------------------------------------------------------------------
#
# These values run after YOLO class filtering and before mission/control sees a
# target. If the selected green box jumps or disappears, tune this section first.
# Do not try to fix a flickering target by increasing visual-servo gains.
GATE_SELECTOR_MIN_SEEK_CONFIDENCE="0.40"
GATE_SELECTOR_MIN_TRACK_CONFIDENCE="0.30"
GATE_SELECTOR_MIN_AREA_RATIO="0.0015"
GATE_SELECTOR_MIN_ASPECT_RATIO="0.35"
GATE_SELECTOR_MAX_ASPECT_RATIO="4.0"
# Optional appearance sanity filter for cases where YOLO predicts
# Goals-Detection on non-gates. Keep disabled by default while validating RGB
# camera input; enable only if model false positives remain after RGB is fixed.
GATE_SELECTOR_MIN_APPEARANCE_SCORE="0.0"
GATE_SELECTOR_APPEARANCE_WEIGHT="0.0"
GATE_SELECTOR_STABLE_WINDOW="5"
GATE_SELECTOR_REQUIRED_STABLE="3"

# ---------------------------------------------------------------------------
# 2) Mission timing and distance policy: decide when to brake/pass/land.
# ---------------------------------------------------------------------------
#
# These values decide phase transitions, not control smoothness. If the drone is
# jerky while already in CENTER_GATE, tune section 4 below before changing these.
# CENTER_DWELL keeps visual centering active long enough for ArduPilot and the
# vehicle to settle naturally before a committed forward pass.
MISSION_MAX_DETECTION_AGE="0.75"
MISSION_REQUIRED_DETECTION_TICKS="2"
MISSION_CENTER_DWELL="5.0"
MISSION_CENTER_CLEARANCE_REQUIRED="0.30"
MISSION_CENTER_LOST_GRACE_TICKS="10"
MISSION_SEEK_YAW_RATE="0.30"
MISSION_GATE_PASS_DISTANCE="1.25"
MISSION_GATE_PASS_SPEED="1.20"
MISSION_NEXT_GATE_ACQUIRE_SPEED="1.50"
MISSION_NEXT_GATE_CLEAR_DISTANCE="2.00"
# Image-space bbox area policy. NEXT_GATE_MIN_AREA is the far-gate candidate
# threshold; GATE_READY_AREA is required before brake/center or pass commit.
MISSION_NEXT_GATE_MIN_AREA="0.015"
MISSION_GATE_READY_AREA="0.060"
MISSION_NEXT_GATE_MAX_DISTANCE="6.00"
MISSION_NEXT_GATE_TIMEOUT="6.00"
MISSION_BRAKE_SETTLE="1.00"
# Ramp forward speed down during BRAKE instead of stepping immediately to zero.
# Keep <= MISSION_BRAKE_SETTLE. Lower means harder braking; higher is smoother.
MISSION_BRAKE_RAMP="0.70"
# Keep companion altitude correction off during BRAKE by default. The MAVLink
# command still sends body_vz=0, but it avoids proportional up/down corrections
# fighting the pitch/altitude transient during deceleration. Set 1 only if logs
# show unacceptable altitude drift during brake.
MISSION_BRAKE_ALTITUDE_HOLD="0"
MISSION_FINAL_EXIT_DISTANCE="2.00"
MISSION_FINAL_EXIT_SPEED="1.50"

# ---------------------------------------------------------------------------
# 3) Visual-servo geometry and pass clearance: align the safe vehicle center.
# ---------------------------------------------------------------------------
#
# These values describe camera/image geometry and safe clearance. They should
# not be used as generic smoothness knobs. Tune target offsets if the camera
# optical center is not the same as the safe vehicle centerline. Positive x
# means the accepted gate center may sit right of the target; positive y means
# below the target.
VISUAL_FRAME_WIDTH="640"
VISUAL_FRAME_HEIGHT="480"
VISUAL_MIN_CONFIDENCE="0.45"
VISUAL_CENTER_DEADBAND_X="0.070"
VISUAL_CENTER_DEADBAND_Y="0.090"
VISUAL_ALIGNED_ERROR_X="0.075"
VISUAL_ALIGNED_ERROR_Y="0.120"
VISUAL_PASS_TARGET_OFFSET_X="0.0"
VISUAL_PASS_TARGET_OFFSET_Y="0.0"
VISUAL_PASS_CLEARANCE_LEFT="0.090"
VISUAL_PASS_CLEARANCE_RIGHT="0.090"
VISUAL_PASS_CLEARANCE_UP="0.130"
VISUAL_PASS_CLEARANCE_DOWN="0.130"
VISUAL_MAX_ERROR_FOR_FORWARD="0.450"
VISUAL_MIN_FORWARD_SPEED="0.00"

# ---------------------------------------------------------------------------
# 4) Visual-servo smoothness: first response to jerky camera/drone motion.
# ---------------------------------------------------------------------------
#
# Current controller is intentionally P + deadband + saturation + low-pass
# filters. It is not PID/FF. For YOLO image-servoing, filtered P is safer than
# adding integral/derivative before the visual signal and vehicle response are
# logged. Tune in this order:
#   1. Lower max speed/rate limits if motion is aggressive.
#   2. Lower VISUAL_COMMAND_FILTER_ALPHA if commands change too sharply.
#   3. Lower VISUAL_FILTER_ALPHA if bbox jitter drives motion.
#   4. Only then reduce KP values.
# Lower alpha = smoother but more lag. Higher alpha = faster but jerkier.
VISUAL_FILTER_ALPHA="0.18"
VISUAL_COMMAND_FILTER_ALPHA="0.25"
VISUAL_MAX_FORWARD_SPEED="0.30"
VISUAL_LATERAL_KP="0.35"
VISUAL_VERTICAL_KP="0.28"
VISUAL_YAW_KP="0.18"
VISUAL_MAX_LATERAL_SPEED="0.22"
VISUAL_MAX_VERTICAL_SPEED="0.16"
VISUAL_MAX_YAW_RATE="0.18"

# This repo's iris_camera.wbt requests true RGB camera frames on TCP port 5599
# through the vendored Webots controller's --camera-format rgb24 argument.
WEBOTS_CAMERA_HOST="127.0.0.1"
WEBOTS_CAMERA_PORT="5599"
WEBOTS_CAMERA_ENCODING="rgb24"
WEBOTS_CAMERA_IDLE_RECONNECT="2.0"
WEBOTS_DETECTION_STALE="0.75"
WEBOTS_DIAGNOSTICS_WINDOW="1"

# Safety default: 0 means do not send MAVLink movement commands.
# Set to 1 only when connected to SITL and ready to let the vehicle move.
SEND_COMMANDS="0"

LOOP_HZ="20"
MAX_RUNTIME="180"

# Course-forward projection from LOCAL_POSITION_NED.
# Defaults to local x/North. Change this when the Webots course direction is known.
COURSE_FORWARD_X="1.0"
COURSE_FORWARD_Y="0.0"
