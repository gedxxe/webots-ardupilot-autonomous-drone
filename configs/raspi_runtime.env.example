# Raspberry Pi hardware runtime template.
#
# Copy this file to configs/raspi_runtime.env on the Raspberry Pi before any
# hardware experiment. This profile is intentionally fail-closed: it connects to
# the Pixhawk and can run the mission loop in dry-run mode, but it does not
# enable a real C920 detector yet and it does not send commands by default.

# Pixhawk over USB serial. If heartbeat fails and Linux created a second ACM
# device, copy this template locally and change to /dev/ttyACM1.
MAVLINK_CONNECTION="/dev/ttyACM0"
MAVLINK_BAUD="115200"

# Real C920/OpenCV perception is future work. Keep DETECTOR=none until the
# hardware camera adapter is implemented and validated in dry-run.
DETECTOR="none"

# Safety default: 0 means no MAVLink motion commands are sent.
SEND_COMMANDS="0"

# Keep the same loop/config shape as simulation so the mission state machine is
# exercised through the same runtime path.
LOOP_HZ="20"
MAX_RUNTIME="180"
COURSE_FORWARD_X="1.0"
COURSE_FORWARD_Y="0.0"

# Hardware notes:
# - ArduPilot EKF owns GPS/rangefinder/optical-flow fusion.
# - The companion consumes fused LOCAL_POSITION_NED telemetry.
# - Do not set SEND_COMMANDS=1 until a hardware safety runbook is followed.
