# Copy this file to configs/sitl_webots.env and adjust paths for your machine.

# ArduPilot must remain outside this repository.
ARDUPILOT_HOME="$HOME/ardupilot"

# Default Webots Python example included in ArduPilot.
WEBOTS_EXAMPLE_RELATIVE="libraries/SITL/examples/Webots_Python"
WEBOTS_WORLD="worlds/iris.wbt"
WEBOTS_PARAM_FILE="params/iris.parm"

# MAVLink endpoint exposed to companion apps.
MAVLINK_OUT="udp:127.0.0.1:14550"

# ArduPilot vehicle/model settings.
ARDUPILOT_VEHICLE="ArduCopter"
ARDUPILOT_MODEL="webots-python"
